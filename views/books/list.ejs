<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Book List</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background-color: #f8f9fa;
    }

    .card {
      border-radius: 12px;
    }
  </style>
</head>

<body>

  <div class="container mt-5">

    <!-- HEADER -->
      <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📚 Book List</h2>
    <div>
      <% if (session?.role === 'customer') { %>
        <a href="/purchases" class="btn btn-success">🛒 Cart</a>
      <% } %>
      <% if (session?.role === 'admin') { %>
        <a href="/books/add" class="btn btn-primary">+ Add Book</a>
      <% } %>
      <a href="/logout" class="btn btn-danger">Logout</a>
    </div>
  </div>

    <!-- ALERT -->
    <% if (query?.msg) { %>
      <div class="alert alert-info">
        <%= query.msg %>
      </div>
    <% } %>

    <!-- SEARCH -->
    <div class="card mb-4 p-3 shadow-sm">
      <form method="GET" action="/books" class="row g-2">
        
        <div class="col-md-10">
          <input 
            type="text"
            name="search"
            class="form-control"
            placeholder="🔍 Search book..."
            value="<%= query?.search || '' %>"
          >
        </div>

        <div class="col-md-2 d-grid">
          <button type="submit" class="btn btn-dark">Search</button>
        </div>

      </form>
    </div>

    <!-- TABLE -->
    <div class="card shadow-sm">
      <div class="table-responsive">

        <table class="table table-hover align-middle mb-0">
          
          <thead class="table-dark">
            <tr>
              <th>#</th>
              <th>Name</th>
              <th>Author</th>
              <th>Price</th>
              <th>Categories</th>
              <th width="200">Action</th>
            </tr>
          </thead>

          <tbody>
            <% if (books.length === 0) { %>
              <tr>
                <td colspan="5" class="text-center py-4 text-muted">
                  No books found 😢
                </td>
              </tr>
            <% } %>

            <% books.forEach((book, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                
                <td>
                  <strong><%= book.name %></strong>
                </td>

                <td>
                  <%= book.Author?.name || '-' %>
                </td>

                <td class="text-success fw-bold">
                  <%= formatRupiah(book.price) %>
                </td>

                <td>
                  <% if (book.Categoris && book.Categoris.length > 0) { %>
                    <% book.Categoris.forEach(cat => { %>
                      <span class="badge bg-secondary me-1">
                        <%= cat.categoriName %>
                      </span>
                    <% }) %>
                  <% } else { %>
                    -
                  <% } %>
                </td>

                <td>
                  <a href="/books/<%= book.id %>" class="btn btn-sm btn-info">Detail</a>

                  <% if (session?.role === 'admin') { %>
                    <a href="/books/<%= book.id %>/edit" class="btn btn-sm btn-warning">Edit</a>
                    <a 
                      href="/books/<%= book.id %>/delete"
                      class="btn btn-sm btn-danger"
                      onclick="return confirm('Yakin hapus buku ini?')"
                    >
                      Delete
                    </a>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>

        </table>

      </div>
    </div>

  </div>

</body>
</html>