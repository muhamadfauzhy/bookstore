<h1>📚 Book List</h1>

<form method="GET" action="/books">
  <input type="text" name="search" placeholder="Search book">
  <button type="submit">Search</button>
</form>

<a href="/books/add">Add Book</a>

<% if (query?.msg) { %>
  <p><%= query.msg %></p>
<% } %>

<table border="1">
  <tr>
    <th>Name</th>
    <th>Author</th>
    <th>Price</th>
    <th>Action</th>
  </tr>

  <% books.forEach(book => { %>
    <tr>
      <td><%= book.name %></td>
      <td><%= book.Author?.name %></td>
      <td><%= formatRupiah(book.price) %></td>
      <td>
        <a href="/books/<%= book.id %>">Detail</a>
        <a href="/books/<%= book.id %>/edit">Edit</a>
        <a href="/books/<%= book.id %>/delete">Delete</a>
      </td>
    </tr>
  <% }) %>
</table>

<br>
<a href="/logout">Logout</a>