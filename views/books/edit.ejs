<h1> Edit Book</h1>

<% if (errors) { %>
  <ul style="color:red; background:#ffecec; padding:10px;">
    <% errors.forEach(err => { %>
      <li><%= err %></li>
    <% }) %>
  </ul>
<% } %>

<form method="POST" action="/books/<%= book.id %>/edit">
  <input name="name" value="<%= book.name %>"><br>
  <input name="description" value="<%= book.description %>"><br>
  <input name="price" value="<%= book.price %>">

  <select name="AuthorId">
    <% authors.forEach(a => { %>
      <option value="<%= a.id %>" <%= a.id === book.AuthorId ? 'selected' : '' %>>
        <%= a.name %>
      </option>
    <% }) %>
  </select>

  <h3>Categories</h3>
  <% categories.forEach(c => { %>
    <input 
      type="checkbox" 
      name="categoryIds" 
      value="<%= c.id %>"

      <%= book.Categoris.some(cat => cat.id === c.id) ? 'checked' : '' %>
    >
    <%= c.categoriName %><br>
  <% }) %>

  <button type="submit">Update</button>
</form>