<style>
  .container {
    max-width: 700px;
    margin: 60px auto;
    font-family: Arial, sans-serif;
  }

  .card {
    border: 1px solid #ddd;
    border-radius: 12px;
    padding: 24px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
  }

  .title {
    font-size: 24px;
    font-weight: bold;
    margin-bottom: 20px;
  }

  .table {
    width: 100%;
    border-collapse: collapse;
  }

  .table th {
    text-align: left;
    background: #f3f3f3;
    padding: 10px;
  }

  .table td {
    padding: 10px;
    border-top: 1px solid #eee;
  }

  .table tr:hover {
    background: #fafafa;
  }

  .empty {
    text-align: center;
    color: #777;
    padding: 20px;
  }

  .btn {
    display: inline-block;
    margin-top: 20px;
    padding: 10px 16px;
    border-radius: 8px;
    text-decoration: none;
    font-size: 14px;
    background: #6c757d;
    color: white;
  }

  .btn:hover {
    background: #545b62;
  }

  .badge {
    background: #007bff;
    color: white;
    padding: 4px 10px;
    border-radius: 8px;
    font-size: 12px;
  }
</style>

<div class="container">
  <div class="card">
    <div class="title">📜 Purchase History</div>

    <% if (purchases.length === 0) { %>
      <div class="empty">Belum ada riwayat pembelian</div>
    <% } else { %>
      <table class="table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Total Buku</th>
          </tr>
        </thead>
        <tbody>
          <% purchases.forEach(p => { %>
            <tr>
              <td>#<%= p.id %></td>
              <td>
                <span class="badge">
                  <%= p.Books.length %> buku
                </span>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>

    <a href="/purchases" class="btn">⬅ Back</a>
  </div>
</div>