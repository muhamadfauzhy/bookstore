<style>
  .container {
    max-width: 600px;
    margin: 40px auto;
    font-family: Arial, sans-serif;
  }

  .card {
    border: 1px solid #ddd;
    border-radius: 12px;
    padding: 20px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
  }

  .title {
    font-size: 24px;
    font-weight: bold;
    margin-bottom: 15px;
  }

  .label {
    font-weight: bold;
    color: #555;
  }

  .value {
    margin-bottom: 10px;
  }

  .categories {
    margin-top: 10px;
  }

  .categories li {
    background: #f3f3f3;
    display: inline-block;
    padding: 5px 10px;
    margin: 3px;
    border-radius: 8px;
    font-size: 14px;
  }

  .back-btn {
    display: inline-block;
    margin-top: 20px;
    padding: 8px 15px;
    background: #007bff;
    color: white;
    text-decoration: none;
    border-radius: 6px;
  }

  .back-btn:hover {
    background: #0056b3;
  }
</style>

<div class="container">
  <div class="card">
    <div class="title">📚 Book Detail</div>

    <p class="value">
      <span class="label">Name:</span>
      <%= book.name %>
    </p>

    <p class="value">
      <span class="label">Description:</span>
      <%= book.description %>
    </p>

    <p class="value">
      <span class="label">Price:</span>
      <%= formatRupiah(book.price) %>
    </p>

    <p class="value">
      <span class="label">Author:</span>
      <%= book.Author?.name || 'Unknown' %>
    </p>

    <div class="categories">
      <span class="label">Categories:</span>
      <ul>
        <% book.Categoris.forEach(el => { %>
          <li><%= el.categoriName %></li>
        <% }) %>
      </ul>
    </div>

    <a href="/books" class="back-btn">⬅ Back</a>
  </div>
</div>