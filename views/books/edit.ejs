<h1> Edit Book</h1>

<form method="POST" action="/books/<%= book.id %>/edit">
  <input name="name" value="<%= book.name %>"><br>
  <input name="description" value="<%= book.description %>"><br>
  <input name="price" value="<%= book.price %>"><br>

  <select name="AuthorId">
    <% authors.forEach(a => { %>
      <option value="<%= a.id %>" <%= a.id === book.AuthorId ? 'selected' : '' %>>
        <%= a.name %>
      </option>
    <% }) %>
  </select>

  <h3>Categories</h3>
  <% categories.forEach(c => { %>
    <input type="checkbox" name="categoryIds" value="<%= c.id %>">
    <%= c.categoriName %><br>
  <% }) %>

  <button type="submit">Update</button>
</form>